<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>ToDoApp</display-name>

    <!-- Servlet Declarations -->
    <servlet>
        <servlet-name>register</servlet-name>
        <servlet-class>p1.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>p1.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>p1.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>addTask</servlet-name>
        <servlet-class>p1.AddTaskServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>viewTasks</servlet-name>
        <servlet-class>p1.ViewTasksServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>deleteTask</servlet-name>
        <servlet-class>p1.DeleteTaskServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>updateStatus</servlet-name>
        <servlet-class>p1.UpdateStatusServlet</servlet-class>
    </servlet>

    <!-- Servlet Mappings -->
    <servlet-mapping>
        <servlet-name>register</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>addTask</servlet-name>
        <url-pattern>/addTask</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>viewTasks</servlet-name>
        <url-pattern>/viewTasks</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>deleteTask</servlet-name>
        <url-pattern>/deleteTask</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>updateStatus</servlet-name>
        <url-pattern>/updateStatus</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>